{
  "name": "trustico-mcp",
  "version": "1.0.0",
  "description": "MCP Server pre kompletný lookup slovenských firiem z oficiálnych štátnych registrov SR",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "trustico",
    "slovak",
    "company",
    "registry"
  ],
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "canvas": "^3.2.2",
    "dotenv": "^17.3.1",
    "pdf-parse": "^2.4.5",
    "soap": "^1.8.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
