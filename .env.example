# TrustICO MCP Server — Environment Variables
# Skopíruj ako .env a vyplň hodnoty

# === Server ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug                    # debug | info | warn | error

# === API Keys (povinné pre produkciu) ===
FINSPR_API_KEY=                    # Finančná správa SR — registrácia: https://opendata.financnasprava.sk/page/openapi

# === MCP Server Auth ===
MCP_API_KEY=                       # Bearer token pre prístup k MCP serveru (vygeneruj: openssl rand -hex 32)

# === Timeouts (ms) ===
ADAPTER_TIMEOUT=8000               # Timeout per API adapter request
FULL_PROFILE_TIMEOUT=15000         # Celkový timeout pre company_full_profile
RUZ_PIPELINE_TIMEOUT=20000         # Timeout pre RegisterUZ pipeline (s PDF)

# === Rate Limits (req/min) ===
RATE_RPO=30
RATE_RUZ=30
RATE_RPVS=20
RATE_FINSPR=15
RATE_DATAHUB=50
RATE_ITMS=30
RATE_REPLIK=20
RATE_VIES=10

# === API Base URLs (default, zmeniť len pre testing/staging) ===
# RPO_BASE_URL=https://api.statistics.sk/rpo/v1
# RUZ_BASE_URL=https://www.registeruz.sk/cruz-public
# RPVS_BASE_URL=https://rpvs.gov.sk/OpenData
# FINSPR_BASE_URL=https://iz.opendata.financnasprava.sk/api
# DATAHUB_BASE_URL=https://datahub.ekosystem.slovensko.digital/api/data
# ITMS_BASE_URL=https://opendata.itms2014.sk/v2
# REPLIK_BASE_URL=https://replik-ws.justice.sk/ru-verejnost-ws
# VIES_BASE_URL=https://ec.europa.eu/taxation_customs/vies/rest-api
